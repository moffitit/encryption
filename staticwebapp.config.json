{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.html", "*.js", "*.css", "*.png", "*.json", "*.xml"]
  },
  "mimeTypes": {
    ".xml": "text/xml",
    ".html": "text/html",
    ".js": "application/javascript",
    ".json": "application/json"
  },
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, OPTIONS",
    "Access-Control-Allow-Headers": "Content-Type"
  }
}
